## Install Component ##

helm upgrade --install cert-manager oci://quay.io/jetstack/charts/cert-manager \
  --version v1.20.0 \
  --namespace cert-manager \
  --create-namespace \
  --set crds.enabled=true \
  --set nodeSelector.agentpool=infra \
  --set webhook.nodeSelector.agentpool=infra \
  --set cainjector.nodeSelector.agentpool=infra
