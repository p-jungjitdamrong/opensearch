## Install Component ##
# 0. cert-manager
helm upgrade --install cert-manager oci://quay.io/jetstack/charts/cert-manager \
  --version v1.20.0 \
  --namespace cert-manager \
  --create-namespace \
  --set crds.enabled=true \
  --set nodeSelector.agentpool=infra \
  --set webhook.nodeSelector.agentpool=infra \
  --set cainjector.nodeSelector.agentpool=infra

# 1. istio-base (CRDs)
# ติดตั้ง istioctl ก่อนถ้ายังไม่มี
curl -sL https://istio.io/downloadIstio | ISTIO_VERSION=1.29.1 sh -
export PATH=$PWD/istio-1.29.1/bin:$PATH

helm upgrade --install istio-base istio/base \
  -n istio-system \
  --create-namespace

# 2. istiod (control plane)
helm upgrade --install istiod istio/istiod \
  -n istio-system \
  --set pilot.nodeSelector.agentpool=infra \
  --wait

# 3. istio-ingress (gateway)
helm upgrade --install istio-ingress istio/gateway \
  -n istio-system \
  --set nodeSelector.agentpool=infra \
  --set service.type=LoadBalancer \
  --wait

# 4. Opensearch-Operator
helm repo add opensearch-operator https://opensearch-project.github.io/opensearch-k8s-operator/
helm upgrade --install opensearch-operator opensearch-operator/opensearch-operator -n opensearch-operator --create-namespace -f operator/helm-values.yaml

# 5. Strimzi-Operator
helm repo add strimzi https://strimzi.io/charts/
helm repo update
helm upgrade --install strimzi-kafka-operator strimzi/strimzi-kafka-operator \
  -n strimzi-system \
  --create-namespace \
  --set nodeSelector.agentpool=infra \
  --set watchNamespaces={poc-cluster}

# 6. AKHQ
helm repo add akhq https://akhq.io/
helm repo update
helm upgrade --install akhq akhq/akhq \
  -n poc-cluster \
  --set ingress.enabled=false \
  --set configuration.micronaut.server.context-path=/akhq \
  --set livenessProbe.httpGet.path=/akhq/api/health \
  --set readinessProbe.httpGet.path=/akhq/api/health \
  --set configuration.akhq.connections.poc-kafka.properties.bootstrap\.servers=poc-kafka-kafka-bootstrap:9092




